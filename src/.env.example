# Kopiere diese Datei nach .env und fuege deine lokalen Werte ein:
#   cp .env.example .env
#
# WICHTIG: .env niemals committen!

# HuggingFace Token fuer Datasets/Modelle.
# Das Projekt uebernimmt diesen Wert automatisch als HF_TOKEN und
# HUGGING_FACE_HUB_TOKEN, lokal wie auch im Docker-Python-Pfad.
HF_TOKEN=hf_your_token_here

# Konfigurationsprofil ("local", "uni", ...)
LLM_ROUTING_PROFILE=local
